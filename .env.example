# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Expo (prefix with EXPO_PUBLIC_ for client access)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# DeepSeek AI
DEEPSEEK_API_KEY=your-deepseek-api-key

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Upstash Redis (optional caching layer)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# External providers (all free tiers — app works without any of these set)
# ============================================================

# CollegeFootballData — free w/ account at collegefootballdata.com
CFBD_API_KEY=

# Reddit — create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cfbsocial/1.0 (by /u/yourname)

# NewsAPI.org — 100 req/day free
NEWSAPI_KEY=

# YouTube Data v3 — 10k units/day free (Google Cloud console)
YOUTUBE_API_KEY=

# Giphy — free tier
GIPHY_API_KEY=

# OpenWeather — optional; NWS is primary and keyless. 1000/day free.
OPENWEATHER_API_KEY=

# Google Perspective — free toxicity scoring
PERSPECTIVE_API_KEY=

# Cloudflare Turnstile — free CAPTCHA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend — 3k emails/month free
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@yourdomain.com

# Alternate AI providers (free tiers)
GROQ_API_KEY=
GEMINI_API_KEY=

# AI provider router weights (default: 100% deepseek when unset)
# Example: deepseek:70,groq:20,gemini:10
AI_PROVIDER_WEIGHTS=

# AI daily caps (defaults in code: 500 calls / $0.50)
AI_DAILY_CALL_CAP=
AI_DAILY_COST_CAP_USD=
